{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2022",
    "lib": ["es2022"],
    "types": ["node"],
    "outDir": "./dist",
    "rootDir": "./",
    "sourceMap": true,
    "declaration": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleDetection": "force",
    "noUncheckedIndexedAccess": true
  },
  "include": [
    "bin/**/*.ts",
    "apps/**/*.ts",
    "config/**/*.ts",
    "packages/**/*.ts",
    "tests/**/*.ts"
, "packages/dna/analysis/callgraph.ts", "packages/dna/analysis/imports.ts", "packages/dna/analysis/naming.ts", "packages/dna/analysis/structure.ts"  ],
  "exclude": ["node_modules", "dist"]
}