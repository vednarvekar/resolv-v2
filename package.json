{
  "name": "resolv",
  "version": "1.0.0",
  "description": "In-Context, Style-Matching Issue Resolver CLI",
  "type": "module",
  "bin": {
    "resolv": "./dist/bin/resolv.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
