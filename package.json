{
  "name": "resolv",
  "version": "2.0.0",
  "description": "Style-matching GitHub issue resolver CLI",
  "type": "module",
  "bin": {
    "resolv": "./dist/bin/resolv.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "dev": "tsx bin/resolv.ts",
    "start": "node dist/bin/resolv.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@google/generative-ai": "^0.24.1",
    "@octokit/rest": "^21.0.0",
    "chalk": "^5.6.2",
    "commander": "^12.0.0",
    "ollama": "^0.6.3",
    "ora": "^9.4.0",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "github",
    "issues",
    "cli",
    "ai",
    "code-generation",
    "llm",
    "anthropic",
    "gemini"
  ],
  "license": "MIT"
}