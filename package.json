    "octokit": "^4.0.0",
    "ora": "^9.4.0",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/node": "^22.19.21",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
