# Required — get a free key at https://build.nvidia.com
NVIDIA_API_KEY=

# Optional — needed to push branches and open PRs. Without it, fixes stay committed locally.
GITHUB_TOKEN=

# Optional overrides (defaults shown)
RESOLV_MODEL=meta/llama-3.3-70b-instruct
RESOLV_TEST_COMMAND=npm test
RESOLV_MAX_ATTEMPTS=4
